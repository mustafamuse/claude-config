+def extract_tab_id(doc_ref: str) -> Optional[str]:
+    """Extract tab ID from a Google Docs URL (?tab=t.xxx). Returns None if absent."""
+    if "?" not in doc_ref:
+        return None
+    query = doc_ref.split("?", 1)[1].split("#", 1)[0]
+    for pair in query.split("&"):
+        if pair.startswith("tab="):
+            tab = pair[4:]
+            return tab or None
+    return None
+
+
+def find_tab(tabs: list, target_id: str) -> Optional[dict]:
+    """Recursively search a tabs tree for a tab with tabProperties.tabId == target_id."""
+    for tab in tabs:
+        props = tab.get("tabProperties", {})
+        if props.get("tabId") == target_id:
+            return tab
+        found = find_tab(tab.get("childTabs") or [], target_id)
+        if found is not None:
+            return found
+    return None
+
+
+def list_tab_ids(tabs: list, prefix: str = "") -> list:
+    """Flatten the tabs tree to a list of 'tabId (title)' strings for error messages."""
+    out = []
+    for tab in tabs:
+        p = tab.get("tabProperties", {})
+        out.append(f"{p.get('tabId')!r} ({p.get('title')!r})")
+        out.extend(list_tab_ids(tab.get("childTabs") or [], prefix))
+    return out
+
+
